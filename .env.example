# =============================================================================
# ModelClone — environment template (copy to .env and fill in values)
# Safe to commit; no real secrets. For Railway: set these in the dashboard.
# =============================================================================

# ---- App (Railway / main backend) ----
NODE_ENV=production
PORT=5000
SERVER_PORT=5000

# Frontend API base (production: your Railway app URL, e.g. https://your-app.up.railway.app)
VITE_API_URL=https://your-app.up.railway.app

# Required in production
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
SESSION_SECRET=generate-a-long-random-string
JWT_SECRET=generate-a-long-random-string

# ---- FFmpeg worker (externalise jobs to Hetzner) ----
# When set, repurpose jobs are sent to this worker instead of running locally/WASM.
FFMPEG_WORKER_URL=https://ffmpeg-worker.your-hetzner-server.com
FFMPEG_WORKER_API_KEY=shared-secret-between-railway-and-worker

# ---- R2 / storage (required for worker path and uploads) ----
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ---- Generation history (auto-prune) ----
# After each completed generation, oldest completed rows per (user, model) are deleted if over cap.
# Default when unset: 200. Set to 0 to disable pruning (users keep full history; higher R2/DB use).
# MAX_COMPLETED_GENERATIONS_PER_MODEL=0

# ---- AI provider keys (balances shown in Admin → Provider API balances) ----
# KIE_API_KEY=
# OPENROUTER_API_KEY=   # use a management key for /credits in OpenRouter dashboard
# FAL_API_KEY=
# WAVESPEED_API_KEY=
# APIFY_API_TOKEN=
# ELEVENLABS_API_KEY=

# ---- Optional: Auth, payments, AI, etc. (add as needed) ----
# STRIPE_SECRET_KEY=
# VITE_STRIPE_PUBLIC_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# RESEND_API_KEY=
# FIREBASE_*=
# OPENROUTER_API_KEY=
# etc.
